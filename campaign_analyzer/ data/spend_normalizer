def normalize_medium(raw: str) -> str:
    """Case-insensitive match raw medium string to canonical value."""
    key = raw.strip().lower()
    return MEDIUM_ALIASES.get(key, "Other")


def _build_mapping_prompt(columns: list[str], sample_rows: list[list]) -> str:
    sample_str = "\n".join(str(row) for row in sample_rows[:5])
    return f"""You are a data mapping assistant for a political advertising analytics tool.

The user has uploaded a spend file with these columns:
{json.dumps(columns)}

Here are the first few data rows:
{sample_str}

Map each source column to one of these canonical target columns (or null if no match):
{json.dumps(CANONICAL_COLUMNS)}

Also identify any columns that represent advertising medium spend amounts.
For medium columns, map to one of these canonical media:
{json.dumps(CANONICAL_MEDIA)}

Return ONLY valid JSON in this exact format:
{{
  "column_mapping": {{
    "<source_col>": "<canonical_col_or_null>"
  }},
  "medium_columns": {{
    "<source_col>": "<canonical_medium>"
  }},
  "notes": "<brief explanation of any ambiguous mappings>"
}}"""


