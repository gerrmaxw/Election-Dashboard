def fetch_civicapi_elections(state: str) -> list[dict]:
    """Fetch election contests for a state from the Google Civic Information API."""
    if not CIVIC_API_KEY:
        return []
    _civic_limiter.wait()
    try:
        r = requests.get(
            f"{CIVIC_BASE}/elections",
            params={"key": CIVIC_API_KEY},
            timeout=20,
        )
        r.raise_for_status()
